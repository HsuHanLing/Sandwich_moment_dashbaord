# BigQuery Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLOUD_PROJECT=your-project-id
BIGQUERY_DATASET=your_dataset
BIGQUERY_TABLE=your_table

# Optional: Path to service account JSON (for server/auth)
# If not set, uses Application Default Credentials (ADC)
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json

# Column mapping - adjust to match your BigQuery schema
# Common marketing columns (use your actual column names):
# date_column=date (or created_at, event_date, etc.)
# campaign_column=campaign_name (or campaign, etc.)
# channel_column=channel (or source, medium, etc.)
# spend_column=cost (or spend, ad_spend, etc.)
# impressions_column=impressions
# clicks_column=clicks
# conversions_column=conversions
# revenue_column=revenue (or value, etc.)
